{
  "name": "datanauts-desktop",
  "version": "1.0.0",
  "description": "DataNauts HUB - Desktop App",
  "author": {
    "name": "DataNauts",
    "email": "support@datanauts.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.datanauts.hub",
    "productName": "DataNauts HUB",
    "copyright": "Copyright © 2026 DataNauts",
    "artifactName": "DataNauts-HUB-Setup.${ext}",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": ["dmg"],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "deleteAppDataOnUninstall": true
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
